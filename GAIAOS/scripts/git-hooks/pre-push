#!/bin/bash
# Installed as .git/hooks/pre-push
# Phase 1: Franklin (treasury/MCP canaries when protected paths change)
# Phase 2: M8 refuse (protected refs main/develop — no delete / no non-FF)
# Both must pass. stdin is consumed once; saved for M8 after Franklin.

REPO_ROOT="$(git rev-parse --show-toplevel)"
HOOKS_DIR="${REPO_ROOT}/GAIAOS/scripts/git-hooks"

TMP="$(mktemp)"
trap 'rm -f "$TMP"' EXIT
cat > "$TMP"

bash "$HOOKS_DIR/pre-push-franklin" "$@" || exit $?
bash "$HOOKS_DIR/pre-push-m8-refuse" < "$TMP"
