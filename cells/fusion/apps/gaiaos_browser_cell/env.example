# ═══════════════════════════════════════════════════════
# GAIAOS BROWSER CELL - FLATCAR-FIRST CONFIGURATION
# ═══════════════════════════════════════════════════════
#
# NOTE: This repo blocks committing dot-env template files (e.g. `.env.example`).
# Use this file as the canonical template:
#
#   cp apps/gaiaos_browser_cell/env.example apps/gaiaos_browser_cell/.env
#

# Make single-cell the default when you run `docker compose up -d`
# - single-cell: includes local ArangoDB container
# - multi-cell: expects external ARANGO_URL
# - monitoring: adds Prometheus + Grafana
COMPOSE_PROFILES=single-cell

# ───────────────────────────────────────────────────────
# CELL IDENTITY
# ───────────────────────────────────────────────────────
CELL_ID=browser_cell_01
DEPLOYMENT_ENV=production

# ───────────────────────────────────────────────────────
# NETWORK & PORTS
# ───────────────────────────────────────────────────────
UI_PORT=8896
TRANSPORT_PORT=8792
EXPORTER_PORT=8897

# Optional: expose local ArangoDB port in single-cell mode
ARANGO_PORT=8529

# ───────────────────────────────────────────────────────
# EXTERNAL SERVICES (MULTI-CELL DEPLOYMENT)
# ───────────────────────────────────────────────────────
# For multi-cell, point ARANGO_URL at the substrate cell (or any reachable ArangoDB)
ARANGO_URL=http://10.0.0.10:8529
ARANGO_DB=gaiaos_substrate
ARANGO_USER=gaiaos
ARANGO_PASSWORD=changeme_in_production

# Single-cell ArangoDB container root password (only used by arangodb service)
ARANGO_ROOT_PASSWORD=changeme_in_production

# ───────────────────────────────────────────────────────
# STORAGE (FLATcar-SPECIFIC PATHS)
# ───────────────────────────────────────────────────────
# Use Flatcar host persistence under /var/lib/gaiaos
USD_BASE_PATH=/var/lib/gaiaos/browser_cell_01/usd
PUBLIC_SCENES_PATH=/var/lib/gaiaos/browser_cell_01/public_scenes
GLB_ASSETS_PATH=/var/lib/gaiaos/browser_cell_01/glb_assets

ARANGO_DATA_PATH=/var/lib/gaiaos/browser_cell_01/arangodb
ARANGO_APPS_PATH=/var/lib/gaiaos/browser_cell_01/arangodb-apps

PROMETHEUS_DATA_PATH=/var/lib/gaiaos/browser_cell_01/prometheus
GRAFANA_DATA_PATH=/var/lib/gaiaos/browser_cell_01/grafana

# ───────────────────────────────────────────────────────
# WEATHER PROVIDERS (CAPABILITY-GATED)
# ───────────────────────────────────────────────────────
ENABLE_AVIATION_WEATHER=0
METAR_STATIONS=KJFK,KBOS,KLAX,KORD,KATL,KSEA,KDFW,KDEN

ENABLE_NOAA_NWS=0
NWS_POINT_LAT=39.8283
NWS_POINT_LON=-98.5795
NWS_USER_AGENT=GaiaOS/1.0 (browser_cell_01)

WEATHER_POLL_SEC=300

# ───────────────────────────────────────────────────────
# ATC AIRCRAFT PROVIDERS (REAL, RATE-LIMITED)
# ───────────────────────────────────────────────────────

# Aircraft source for Cell-world ATC feed:
# - opensky: OpenSky `/states/all` tiles (may rate-limit; credentials recommended)
# - airplanes_live: airplanes.live `/v2/point/{lat}/{lon}/{radius}` (explicit 1 req/sec)
ATC_ADSB_SOURCE=airplanes_live
ATC_ADSB_FALLBACK_ON_429=1

# airplanes.live base URL (documented at https://airplanes.live/api-guide/)
AIRPLANES_LIVE_BASE_URL=https://api.airplanes.live/v2

# ATC poll cadence (seconds). Keep >= 1.0 to respect 1 req/sec sources.
ATC_POLL_SEC=1.0

# Default ATC region radius (km) when not using a corridor preset.
ATC_RADIUS_KM_DEFAULT=150

# Corridor preset for tile rotation (NE_FULL = DC/PHL/NYC/BDL/BOS)
ATC_CORRIDOR_PRESET=NE_FULL

# OpenSky credentials (optional, improves limits when ATC_ADSB_SOURCE=opensky)
OPENSKY_USER=
OPENSKY_PASS=

# ───────────────────────────────────────────────────────
# USD / EXPORT
# ───────────────────────────────────────────────────────
EXPORT_RATE_HZ=1

# ───────────────────────────────────────────────────────
# RESOURCE LIMITS (PRODUCTION)
# NOTE: Enforced under Swarm. Still useful as a deployment contract for Flatcar.
# ───────────────────────────────────────────────────────
TRANSPORT_CPU_LIMIT=1.0
TRANSPORT_MEM_LIMIT=512m

EXPORTER_CPU_LIMIT=0.5
EXPORTER_MEM_LIMIT=256m

NGINX_CPU_LIMIT=0.25
NGINX_MEM_LIMIT=128m

# ───────────────────────────────────────────────────────
# MONITORING (OPTIONAL)
# ───────────────────────────────────────────────────────
PROMETHEUS_PORT=9091
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_in_production

# ───────────────────────────────────────────────────────
# LOGGING
# ───────────────────────────────────────────────────────
LOG_LEVEL=INFO


