FROM rust:1.85-bookworm as builder

WORKDIR /app

COPY Cargo.toml ./
RUN mkdir -p src && echo "fn main(){}" > src/main.rs
RUN cargo build --release
RUN rm -rf src

COPY src ./src
RUN cargo build --release

FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y ca-certificates && rm -rf /var/lib/apt/lists/*

COPY --from=builder /app/target/release/field_observation_builder /usr/local/bin/field_observation_builder

ENV RUST_LOG=info
CMD ["field_observation_builder"]


