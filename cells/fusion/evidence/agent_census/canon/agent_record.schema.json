{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["agent_id", "agent_name", "runtime_type", "declared_capabilities", "agrees_to_witness_gate", "registered_at"],
  "properties": {
    "agent_id": {
      "type": "string",
      "format": "uuid"
    },
    "agent_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-zA-Z0-9_-]+$"
    },
    "runtime_type": {
      "type": "string",
      "enum": ["local", "cloud", "unknown"]
    },
    "declared_capabilities": {
      "type": "object",
      "additionalProperties": {
        "type": "boolean"
      }
    },
    "agrees_to_witness_gate": {
      "type": "boolean"
    },
    "operator_contact": {
      "type": "string"
    },
    "registered_at": {
      "type": "string",
      "format": "date-time"
    },
    "capability_proofs": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "verdict": {
            "type": "string",
            "enum": ["PROVEN", "FAILED", "UNPROVEN"]
          },
          "proof_id": {
            "type": "string"
          },
          "verified_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "violation_history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["reason_code", "detected_at", "evidence_file"],
        "properties": {
          "reason_code": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium"]
          },
          "detected_at": {
            "type": "string",
            "format": "date-time"
          },
          "evidence_file": {
            "type": "string"
          }
        }
      }
    },
    "failed_proof_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Count of FAILED proof submissions"
    },
    "last_activity": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
