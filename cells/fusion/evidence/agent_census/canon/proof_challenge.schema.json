{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["challenge_id", "agent_id", "capability_id", "nonce", "instructions", "issued_at", "expires_at"],
  "properties": {
    "challenge_id": {
      "type": "string",
      "format": "uuid"
    },
    "agent_id": {
      "type": "string",
      "format": "uuid"
    },
    "capability_id": {
      "type": "string",
      "enum": ["WEB_FETCH", "CODE_RUN", "FILE_WRITE", "HTTP_API_CALL", "EMAIL_SEND", "SMS_SEND", "SSH_CONNECT", "TASK_SCHEDULE", "WALLET_SIGN", "TRADE_EXECUTE", "AGENT_COORDINATE"]
    },
    "nonce": {
      "type": "string",
      "minLength": 1
    },
    "instructions": {
      "type": "string",
      "minLength": 1
    },
    "verification_endpoint": {
      "type": "string"
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
