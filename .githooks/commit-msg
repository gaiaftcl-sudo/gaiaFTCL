#!/usr/bin/env bash
# .githooks/commit-msg — reject commits without terminal state
msg=$(head -n1 "$1")
if ! echo "$msg" | grep -qE '^(CALORIE|CURE|REFUSED|BLOCKED)\([a-z0-9-]+\):'; then
  echo "REFUSED: commit message must start with CALORIE|CURE|REFUSED|BLOCKED(scope): …"
  echo "Got: $msg"
  exit 1
fi
# Reject known typos
if git diff --cached | grep -qE '\bgaitfc[l]\b'; then
  echo "REFUSED: 'g-a-i-t-f-c-l' typo detected in staged changes."
  exit 1
fi
# Block anything looking like an external LLM key or anthropic API call in code
if git diff --cached | grep -qE '(sk-an[t]-|api\.anthropic\.com|openai\.com/v1)'; then
  echo "REFUSED: external LLM endpoint/key in staged changes — sovereignty violation."
  exit 1
fi
exit 0
